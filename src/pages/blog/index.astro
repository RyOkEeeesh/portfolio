---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { ContentsSchema, StatusSchema } from '@/schema';
import { POSTS } from '@/store';

const blogs: CollectionEntry<typeof POSTS>[] = await getCollection(
  POSTS,
  post => post.data.contentType === ContentsSchema.enum.blog && post.data.status === StatusSchema.enum.published,
);

blogs.sort((a, b) => b.data.createdAt.valueOf() - a.data.createdAt.valueOf());
---

<Layout title="ブログ一覧">
  <main>
    <a href="/">← トップへ戻る</a>
    <h1>Blog</h1>
  
    {
      blogs.length === 0 ? (
        <p>記事がありません。</p>
      ) : (
        <ul>
          {blogs.map(post => (
            <li>
              <span>{post.data.createdAt.toLocaleDateString()}</span>
              <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>

<style>
  h1 {
    border-bottom: 2px solid #eee;
    padding-bottom: 10px;
  }
  ul {
    list-style: none;
    padding: 0;
    li {
      margin-bottom: 20px;
      border: 1px solid #ddd;
      padding: 15px;
      border-radius: 8px;
      span{
        font-size: 0.85rem;
        color: #666;
      }
      h2 {
        margin: 5px 0 10px 0;
        font-size: 1.3rem;
        a {
          color: #0066cc;
          text-decoration: none;
        }
      }
      p {
        margin: 0;
        color: #444;
        font-size: 0.95rem;
      }
    }
  }
</style>