---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import { POSTS } from '@/constants';
import Layout from '@/layouts/Layout.astro';
import { StatusSchema } from '@/schema';

export async function getStaticPaths() {
  const blogs = await getCollection(POSTS, post => post.data.status === StatusSchema.enum.published);

  return blogs.map(post => ({
    // route (contentType) と id (ファイルパス/Slug) の両方を返す
    params: {
      route: post.data.contentType,
      id: post.id,
    },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<typeof POSTS>;
}

const { route } = Astro.params;
const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title}>
  <main>
    <a href={`/${route}`}>← 一覧へ戻る</a>
    <article class="markdown-body">
      <span style="color: #666;"
        >{post.data.createdAt.toLocaleDateString()}</span
      >
      <h1>{post.data.title}</h1>
      <Content />
    </article>
  </main>
</Layout>

<style>
  article {
    margin-top: 20px;
  }
  h1 {
    font-size: 2rem;
    margin-top: 5px;
    border-bottom: 2px solid #eee;
    padding-bottom: 10px;
  }
</style>
