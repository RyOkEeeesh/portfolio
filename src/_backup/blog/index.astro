---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

const blogs: CollectionEntry<'posts'>[] = await getCollection(
  'posts',
  (post: CollectionEntry<'posts'>) => post.data.contentType === 'blog' && post.data.status === 'published',
);

blogs.sort((a, b) => b.data.createdAt.valueOf() - a.data.createdAt.valueOf());
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>ブログ一覧</title>
  </head>
  <body>
    <main
      style="max-width: 600px; margin: 40px auto; padding: 0 20px; font-family: sans-serif;"
    >
      <a href="/">← トップへ戻る</a>
      <h1 style="border-bottom: 2px solid #eee; padding-bottom: 10px;">Blog</h1>

      {
        blogs.length === 0 ? (
          <p>記事がありません。</p>
        ) : (
          <ul style="list-style: none; padding: 0;">
            {blogs.map((post) => (
              <li style="margin-bottom: 20px; border: 1px solid #ddd; padding: 15px; border-radius: 8px;">
                <span style="font-size: 0.85rem; color: #666;">
                  {post.data.createdAt.toLocaleDateString()}
                </span>
                <h2 style="margin: 5px 0 10px 0; font-size: 1.3rem;">
                  <a
                    href={`/blog/${post.id}`}
                    style="color: #0066cc; text-decoration: none;"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <p style="margin: 0; color: #444; font-size: 0.95rem;">
                  {post.data.description}
                </p>
              </li>
            ))}
          </ul>
        )
      }
    </main>
  </body>
</html>
